# === Required: at least one provider must be configured ===

# Claude Code: no key needed, uses your Max subscription
# Just ensure `claude` CLI is installed and authenticated

# Codex: no key needed, uses your ChatGPT subscription
# Just ensure `codex` CLI is installed and authenticated

# === Optional: API-based providers ===
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# === Channel: Telegram ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALLOWED_CHAT_IDS=123456789

# === Channel: Discord ===
# DISCORD_BOT_TOKEN=...
# DISCORD_ALLOWED_USER_IDS=123456789

# === Channel: Slack ===
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USER_IDS=U123456
