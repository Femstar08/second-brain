{
  "name": "second-brain",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "cd web && npm run build && cd .. && tsc",
    "build:server": "tsc",
    "build:web": "cd web && npm run build",
    "dev": "concurrently -n server,web -c blue,green \"tsx src/index.ts\" \"cd web && npx vite\"",
    "dev:server": "tsx src/index.ts",
    "dev:web": "cd web && npx vite",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/claude-code": "^2.1.63",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@openai/codex-sdk": "^0.106.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.0",
    "hono": "^4.12.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
